<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="seq_hospital_enterprise_finance_snapshot" model="ir.sequence">
        <field name="name">Hospital Enterprise Finance Snapshot</field>
        <field name="code">hospital.enterprise.finance.snapshot</field>
        <field name="prefix">FIN-BI/%(y)s/</field>
        <field name="padding">5</field>
    </record>

    <record id="seq_hms_charge" model="ir.sequence">
        <field name="name">Hospital Charge</field>
        <field name="code">hms.charge</field>
        <field name="prefix">CHG/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
