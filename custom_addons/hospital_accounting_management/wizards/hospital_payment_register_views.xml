<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hospital_payment_register_view_form" model="ir.ui.view">
        <field name="name">hospital.payment.register.form</field>
        <field name="model">hospital.payment.register</field>
        <field name="arch" type="xml">
            <form string="Register Hospital Payment">
                <group>
                    <field name="invoice_id"/>
                    <field name="patient_id" readonly="1"/>
                    <field name="amount"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="journal_id"/>
                    <field name="payment_date"/>
                    <field name="communication"/>
                </group>
                <footer>
                    <button name="action_register_payment" string="Register Payment" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
