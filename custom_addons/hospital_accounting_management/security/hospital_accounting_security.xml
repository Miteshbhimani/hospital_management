<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_hospital_cashier" model="res.groups">
        <field name="name">Hospital Cashier</field>
        <field name="category_id" ref="base_hospital_management.base_hospital_management_access"/>
        <field name="implied_ids" eval="[(4, ref('base_hospital_management.base_hospital_management_group_receptionist')), (4, ref('account.group_account_invoice'))]"/>
    </record>
    <record id="group_hospital_accountant" model="res.groups">
        <field name="name">Hospital Accountant</field>
        <field name="category_id" ref="base_hospital_management.base_hospital_management_access"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_invoice'))]"/>
    </record>
    <record id="group_hospital_finance_manager" model="res.groups">
        <field name="name">Hospital Finance Manager</field>
        <field name="category_id" ref="base_hospital_management.base_hospital_management_access"/>
        <field name="implied_ids" eval="[(4, ref('group_hospital_accountant')), (4, ref('account.group_account_manager'))]"/>
    </record>
</odoo>
