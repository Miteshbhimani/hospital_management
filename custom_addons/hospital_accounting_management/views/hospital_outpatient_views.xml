<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hospital_outpatient_view_tree_accounting" model="ir.ui.view">
        <field name="name">hospital.outpatient.list.accounting</field>
        <field name="model">hospital.outpatient</field>
        <field name="inherit_id" ref="base_hospital_management.hospital_outpatient_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="decoration-success">state == 'invoice'</attribute>
            </xpath>
        </field>
    </record>

    <record id="hospital_outpatient_view_form_accounting" model="ir.ui.view">
        <field name="name">hospital.outpatient.form.accounting</field>
        <field name="model">hospital.outpatient</field>
        <field name="inherit_id" ref="base_hospital_management.hospital_outpatient_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_create_lab_test']" position="after">
                <button name="create_invoice" string="Create Invoice" type="object"
                        class="oe_highlight" invisible="state != 'op' or invoiced"
                        groups="hospital_accounting_management.group_hospital_cashier,hospital_accounting_management.group_hospital_accountant,hospital_accounting_management.group_hospital_finance_manager"/>
            </xpath>
            <xpath expr="//header/field[@name='state']" position="attributes">
                <attribute name="statusbar_visible">op,invoice</attribute>
            </xpath>
            <xpath expr="//header/button[@name='action_print_prescription']" position="attributes">
                <attribute name="invisible">state not in ('op','inpatient','invoice')</attribute>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_invoice" type="object" class="oe_stat_button"
                        icon="fa-pencil-square-o" string="Invoice" invisible="not invoice_id"
                        groups="hospital_accounting_management.group_hospital_cashier,hospital_accounting_management.group_hospital_accountant,hospital_accounting_management.group_hospital_finance_manager"/>
                <button name="action_register_hospital_payment" type="object" class="oe_stat_button"
                        icon="fa-credit-card" string="Payment" invisible="not invoice_id"
                        groups="hospital_accounting_management.group_hospital_cashier,hospital_accounting_management.group_hospital_accountant,hospital_accounting_management.group_hospital_finance_manager"/>
            </xpath>
            <xpath expr="//sheet/group[1]" position="after">
                <group name="accounting_group" string="Accounting" groups="hospital_accounting_management.group_hospital_cashier,hospital_accounting_management.group_hospital_accountant,hospital_accounting_management.group_hospital_finance_manager">
                    <group>
                        <field name="payment_state" readonly="1"/>
                        <field name="amount_total" readonly="1"/>
                    </group>
                    <group>
                        <field name="amount_residual" readonly="1"/>
                    </group>
                </group>
                <field name="invoice_id" invisible="1"/>
                <field name="invoiced" invisible="1"/>
            </xpath>
            <xpath expr="//sheet//field[@name='patient_id']" position="attributes">
                <attribute name="readonly">state in ('invoice','cancel')</attribute>
            </xpath>
            <xpath expr="//sheet//field[@name='op_date']" position="attributes">
                <attribute name="readonly">state in ('invoice','cancel')</attribute>
            </xpath>
            <xpath expr="//sheet//field[@name='doctor_id']" position="attributes">
                <attribute name="readonly">state in ('invoice','cancel')</attribute>
            </xpath>
            <xpath expr="//sheet//field[@name='slot']" position="attributes">
                <attribute name="invisible">state not in ('op','inpatient','invoice')</attribute>
                <attribute name="readonly">state in ('invoice','cancel')</attribute>
            </xpath>
            <xpath expr="//sheet/notebook" position="attributes">
                <attribute name="invisible">state not in ('op','inpatient','invoice')</attribute>
            </xpath>
            <xpath expr="//field[@name='prescription_ids']" position="attributes">
                <attribute name="readonly">state in ('invoice','cancel')</attribute>
            </xpath>
        </field>
    </record>
</odoo>
