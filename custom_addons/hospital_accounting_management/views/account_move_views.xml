<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_hospital_accounting" model="ir.ui.view">
        <field name="name">account.move.form.hospital.accounting</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Hospital" name="hospital_accounting" invisible="not hospital_invoice_type">
                    <group>
                        <group>
                            <field name="hospital_patient_id"/>
                            <field name="hospital_invoice_type"/>
                            <field name="hospital_department"/>
                            <field name="hospital_doctor_id"/>
                        </group>
                        <group>
                            <field name="hospital_outpatient_id"/>
                            <field name="hospital_inpatient_id"/>
                            <field name="hospital_lab_test_id"/>
                            <field name="insurance_provider_id"/>
                            <field name="insurance_claim_reference"/>
                        </group>
                    </group>
                    <group string="Split Billing">
                        <field name="patient_amount"/>
                        <field name="insurance_amount"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_invoice_tree_hospital_accounting" model="ir.ui.view">
        <field name="name">account.move.list.hospital.accounting</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <list string="Hospital Invoices" decoration-danger="payment_state in ('not_paid','partial')">
                <field name="name"/>
                <field name="invoice_date"/>
                <field name="hospital_patient_id"/>
                <field name="hospital_invoice_type"/>
                <field name="hospital_department"/>
                <field name="hospital_doctor_id"/>
                <field name="amount_total"/>
                <field name="amount_residual"/>
                <field name="payment_state" widget="badge"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_hospital_invoices" model="ir.actions.act_window">
        <field name="name">Hospital Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('move_type','=','out_invoice'), ('hospital_invoice_type','!=',False)]</field>
        <field name="context">{'default_move_type':'out_invoice'}</field>
    </record>
</odoo>
