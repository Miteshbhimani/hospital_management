<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hospital_branch_view_list" model="ir.ui.view">
        <field name="name">hospital.branch.list</field>
        <field name="model">hospital.branch</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="partner_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="hospital_branch_view_form" model="ir.ui.view">
        <field name="name">hospital.branch.form</field>
        <field name="model">hospital.branch</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1><field name="name"/></h1>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hospital_branch_action" model="ir.actions.act_window">
        <field name="name">Hospital Branches</field>
        <field name="res_model">hospital.branch</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="hospital_branch_menu" name="Hospital Branches"
              parent="hospital_accounting_management.hospital_accounting_menu_root"
              action="hospital_branch_action" sequence="98"
              groups="hospital_accounting_management.group_hospital_accountant,hospital_accounting_management.group_hospital_finance_manager"/>
</odoo>
