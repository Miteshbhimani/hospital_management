<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hospital_corporate_contract_view_list" model="ir.ui.view">
        <field name="name">hospital.corporate.contract.list</field>
        <field name="model">hospital.corporate.contract</field>
        <field name="arch" type="xml"><list><field name="name"/><field name="code"/><field name="partner_id"/><field name="valid_from"/><field name="valid_to"/><field name="credit_limit"/><field name="credit_days"/><field name="active"/></list></field>
    </record>
    <record id="hospital_corporate_contract_view_form" model="ir.ui.view">
        <field name="name">hospital.corporate.contract.form</field>
        <field name="model">hospital.corporate.contract</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1><field name="name"/></h1>
                    <group><group><field name="partner_id"/><field name="code"/><field name="valid_from"/><field name="valid_to"/></group><group><field name="credit_limit"/><field name="credit_days"/><field name="discount_percent"/><field name="payment_term_id"/><field name="active"/></group></group>
                    <group string="Allowed Packages"><field name="package_ids" widget="many2many_tags"/></group>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="hospital_corporate_contract_action" model="ir.actions.act_window"><field name="name">Corporate Contracts</field><field name="res_model">hospital.corporate.contract</field><field name="view_mode">list,form</field></record>

    <record id="hospital_billing_package_view_list" model="ir.ui.view">
        <field name="name">hospital.billing.package.list</field><field name="model">hospital.billing.package</field>
        <field name="arch" type="xml"><list><field name="name"/><field name="code"/><field name="package_type"/><field name="use_fixed_price"/><field name="fixed_price"/><field name="package_amount"/><field name="active"/></list></field>
    </record>
    <record id="hospital_billing_package_view_form" model="ir.ui.view">
        <field name="name">hospital.billing.package.form</field><field name="model">hospital.billing.package</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1><field name="name"/></h1>
                    <group><group><field name="code"/><field name="package_type"/><field name="product_id"/><field name="active"/></group><group><field name="use_fixed_price"/><field name="fixed_price" invisible="not use_fixed_price"/><field name="package_amount" readonly="1"/><field name="valid_from"/><field name="valid_to"/></group></group>
                    <notebook><page string="Package Lines"><field name="line_ids"><list editable="bottom"><field name="sequence" widget="handle"/><field name="product_id"/><field name="name"/><field name="service_type"/><field name="quantity"/><field name="price_unit"/><field name="subtotal" readonly="1"/></list></field></page><page string="Notes"><field name="notes"/></page></notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="hospital_billing_package_action" model="ir.actions.act_window"><field name="name">Billing Packages</field><field name="res_model">hospital.billing.package</field><field name="view_mode">list,form</field></record>

    <record id="hospital_insurance_claim_view_list" model="ir.ui.view">
        <field name="name">hospital.insurance.claim.list</field><field name="model">hospital.insurance.claim</field>
        <field name="arch" type="xml"><list decoration-danger="state == 'rejected'" decoration-success="state == 'settled'" decoration-warning="state in ('preauth_requested','submitted','under_review')"><field name="name"/><field name="claim_date"/><field name="patient_id"/><field name="insurance_provider_id"/><field name="claim_type"/><field name="requested_amount"/><field name="approved_amount"/><field name="patient_payable_amount"/><field name="insurance_payable_amount"/><field name="state" widget="badge"/></list></field>
    </record>
    <record id="hospital_insurance_claim_view_form" model="ir.ui.view">
        <field name="name">hospital.insurance.claim.form</field><field name="model">hospital.insurance.claim</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_request_preauth" string="Request Pre-Auth" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve_preauth" string="Approve Pre-Auth" type="object" invisible="state != 'preauth_requested'"/>
                    <button name="action_submit_claim" string="Submit Claim" type="object" invisible="state not in ('draft','preauth_approved')"/>
                    <button name="action_mark_under_review" string="Under Review" type="object" invisible="state != 'submitted'"/>
                    <button name="action_approve_claim" string="Approve Claim" type="object" invisible="state not in ('submitted','under_review','preauth_approved')"/>
                    <button name="action_settle_claim" string="Settle" type="object" invisible="state != 'approved'"/>
                    <button name="action_reject_claim" string="Reject" type="object" invisible="state in ('settled','rejected','cancelled')"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('settled','cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,preauth_requested,preauth_approved,submitted,approved,settled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"><button name="action_view_invoice" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="not invoice_id"><field name="invoice_id" widget="statinfo" string="Invoice"/></button></div>
                    <h1><field name="name"/></h1>
                    <group>
                        <group><field name="patient_id"/><field name="outpatient_id"/><field name="inpatient_id"/><field name="invoice_id"/><field name="claim_type"/></group>
                        <group><field name="insurance_provider_id"/><field name="policy_number"/><field name="member_id"/><field name="preauth_reference"/><field name="claim_reference"/></group>
                    </group>
                    <group string="Claim Amounts">
                        <group><field name="requested_amount"/><field name="approved_amount"/><field name="settled_amount"/><field name="rejected_amount" readonly="1"/></group>
                        <group><field name="co_pay_percent"/><field name="deductible_amount"/><field name="patient_payable_amount" readonly="1"/><field name="insurance_payable_amount" readonly="1"/></group>
                    </group>
                    <notebook><page string="Timeline"><group><field name="preauth_requested_on"/><field name="preauth_approved_on"/><field name="submitted_on"/><field name="approved_on"/><field name="settled_on"/></group></page><page string="Documents"><field name="document_ids" widget="many2many_binary"/></page><page string="Rejection / Settlement"><field name="rejection_reason"/><field name="settlement_note"/></page></notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="hospital_insurance_claim_action" model="ir.actions.act_window"><field name="name">Insurance / TPA Claims</field><field name="res_model">hospital.insurance.claim</field><field name="view_mode">list,form</field></record>

    <record id="res_partner_form_hospital_phase3" model="ir.ui.view">
        <field name="name">res.partner.form.hospital.phase3</field><field name="model">res.partner</field><field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml"><xpath expr="//notebook" position="inside"><page string="Hospital Corporate"><group><field name="corporate_contract_id"/><field name="employee_code"/></group></page></xpath></field>
    </record>

    <record id="hospital_outpatient_form_phase3_billing" model="ir.ui.view">
        <field name="name">hospital.outpatient.form.phase3.billing</field><field name="model">hospital.outpatient</field><field name="inherit_id" ref="base_hospital_management.hospital_outpatient_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside"><button name="action_view_insurance_claims" type="object" class="oe_stat_button" icon="fa-shield"><field name="insurance_claim_count" widget="statinfo" string="Claims"/></button></xpath>
            <xpath expr="//sheet/group[1]" position="after"><group string="Phase 3 Billing"><field name="corporate_contract_id"/><field name="billing_package_id"/></group></xpath>
        </field>
    </record>
    <record id="hospital_inpatient_form_phase3_billing" model="ir.ui.view">
        <field name="name">hospital.inpatient.form.phase3.billing</field><field name="model">hospital.inpatient</field><field name="inherit_id" ref="base_hospital_management.hospital_inpatient_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside"><button name="action_view_insurance_claims" type="object" class="oe_stat_button" icon="fa-shield"><field name="insurance_claim_count" widget="statinfo" string="Claims"/></button></xpath>
            <xpath expr="//sheet/group[1]" position="after"><group string="Phase 3 Billing"><field name="corporate_contract_id"/><field name="billing_package_id"/></group></xpath>
        </field>
    </record>

    <menuitem id="hospital_insurance_claim_menu" name="Insurance / TPA Claims" parent="hospital_accounting_menu_root" action="hospital_insurance_claim_action" sequence="4"/>
    <menuitem id="hospital_corporate_contract_menu" name="Corporate Contracts" parent="hospital_accounting_menu_root" action="hospital_corporate_contract_action" sequence="5"/>
    <menuitem id="hospital_billing_package_menu" name="Billing Packages" parent="hospital_accounting_menu_root" action="hospital_billing_package_action" sequence="6"/>
</odoo>
