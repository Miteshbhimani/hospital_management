<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_partner_view_form_hospital_accounting" model="ir.ui.view">
        <field name="name">res.partner.form.hospital.accounting</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_hospital_management.res_partner_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_hospital_invoices" type="object" class="oe_stat_button" icon="fa-money">
                    <field name="hospital_invoice_count" widget="statinfo" string="Invoices"/>
                </button>
            </xpath>
            <xpath expr="//sheet/notebook[1]" position="inside">
                <page string="Accounting" name="hospital_accounting">
                    <group string="Financial Summary">
                        <group>
                            <field name="hospital_total_invoiced" readonly="1"/>
                            <field name="hospital_total_paid" readonly="1"/>
                            <field name="hospital_total_residual" readonly="1"/>
                        </group>
                        <group>
                            <field name="insurance_policy_number"/>
                            <field name="insurance_coverage_percent"/>
                            <field name="insurance_partner_id"/>
                            <field name="primary_branch_id"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
