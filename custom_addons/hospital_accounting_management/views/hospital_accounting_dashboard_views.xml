<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hospital_accounting_dashboard_view_list" model="ir.ui.view">
        <field name="name">hospital.accounting.dashboard.list</field>
        <field name="model">hospital.accounting.dashboard</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="name"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="today_revenue"/>
                <field name="monthly_revenue"/>
                <field name="outstanding_receivables"/>
            </list>
        </field>
    </record>

    <record id="hospital_accounting_dashboard_view_form" model="ir.ui.view">
        <field name="name">hospital.accounting.dashboard.form</field>
        <field name="model">hospital.accounting.dashboard</field>
        <field name="arch" type="xml">
            <form create="0" delete="0">
                <header>
                    <button name="action_refresh_dashboard" type="object" string="Refresh" class="btn-primary" icon="fa-refresh"/>
                    <button name="action_open_hospital_invoices" type="object" string="Hospital Invoices" icon="fa-file-text-o"/>
                    <button name="action_open_hospital_payments" type="object" string="Hospital Payments" icon="fa-money"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_hospital_invoices" type="object" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="posted_invoice_count" widget="statinfo" string="Posted Invoices"/>
                        </button>
                        <button name="action_open_outstanding_invoices" type="object" class="oe_stat_button" icon="fa-warning">
                            <field name="unpaid_invoices" widget="statinfo" string="Outstanding"/>
                        </button>
                        <button name="action_open_overdue_invoices" type="object" class="oe_stat_button" icon="fa-clock-o">
                            <field name="overdue_invoices" widget="statinfo" string="Overdue"/>
                        </button>
                        <button name="action_open_insurance_invoices" type="object" class="oe_stat_button" icon="fa-shield">
                            <field name="insurance_invoice_count" widget="statinfo" string="Insurance"/>
                        </button>
                        <button name="action_open_hospital_payments" type="object" class="oe_stat_button" icon="fa-money">
                            <field name="payment_count" widget="statinfo" string="Payments"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group string="Reporting Period">
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                        <group>
                            <field name="currency_id" readonly="1"/>
                            <field name="invoice_count" readonly="1"/>
                            <field name="draft_invoice_count" readonly="1"/>
                        </group>
                    </group>

                    <div class="o_hms_accounting_dashboard">
                        <div class="o_hms_dashboard_section_title">Revenue &amp; Receivables</div>
                        <div class="row g-3">
                            <div class="col-12 col-md-6 col-xl-3"><div class="o_hms_metric_card primary"><span>Today Revenue</span><strong><field name="today_revenue" widget="monetary" readonly="1"/></strong></div></div>
                            <div class="col-12 col-md-6 col-xl-3"><div class="o_hms_metric_card primary"><span>Monthly Revenue</span><strong><field name="monthly_revenue" widget="monetary" readonly="1"/></strong></div></div>
                            <div class="col-12 col-md-6 col-xl-3"><div class="o_hms_metric_card success"><span>Total Revenue</span><strong><field name="total_revenue" widget="monetary" readonly="1"/></strong></div></div>
                            <div class="col-12 col-md-6 col-xl-3"><div class="o_hms_metric_card warning"><span>Outstanding</span><strong><field name="outstanding_receivables" widget="monetary" readonly="1"/></strong></div></div>
                            <div class="col-12 col-md-6 col-xl-3"><div class="o_hms_metric_card danger"><span>Insurance Receivable</span><strong><field name="insurance_receivables" widget="monetary" readonly="1"/></strong></div></div>
                            <div class="col-12 col-md-6 col-xl-3"><div class="o_hms_metric_card success"><span>Payments Collected</span><strong><field name="payments_collected" widget="monetary" readonly="1"/></strong></div></div>
                            <div class="col-12 col-md-6 col-xl-3"><div class="o_hms_metric_card primary"><span>Advance Collected</span><strong><field name="advance_collected" widget="monetary" readonly="1"/></strong></div></div>
                            <div class="col-12 col-md-6 col-xl-3"><div class="o_hms_metric_card danger"><span>Refunds Paid</span><strong><field name="refunds_paid" widget="monetary" readonly="1"/></strong></div></div>
                        </div>

                        <div class="o_hms_dashboard_section_title mt-4">Revenue by Department</div>
                        <div class="row g-3">
                            <div class="col-12 col-md-4 col-xl-2"><div class="o_hms_metric_card compact"><span>OPD</span><strong><field name="opd_revenue" widget="monetary" readonly="1"/></strong></div></div>
                            <div class="col-12 col-md-4 col-xl-2"><div class="o_hms_metric_card compact"><span>IPD</span><strong><field name="ipd_revenue" widget="monetary" readonly="1"/></strong></div></div>
                            <div class="col-12 col-md-4 col-xl-2"><div class="o_hms_metric_card compact"><span>Laboratory</span><strong><field name="laboratory_revenue" widget="monetary" readonly="1"/></strong></div></div>
                            <div class="col-12 col-md-4 col-xl-2"><div class="o_hms_metric_card compact"><span>Pharmacy</span><strong><field name="pharmacy_revenue" widget="monetary" readonly="1"/></strong></div></div>
                            <div class="col-12 col-md-4 col-xl-2"><div class="o_hms_metric_card compact"><span>Radiology</span><strong><field name="radiology_revenue" widget="monetary" readonly="1"/></strong></div></div>
                            <div class="col-12 col-md-4 col-xl-2"><div class="o_hms_metric_card compact"><span>Surgery / Other</span><strong><field name="surgery_revenue" widget="monetary" readonly="1"/></strong></div></div>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hospital_accounting_dashboard" model="ir.actions.act_window">
        <field name="name">Accounting Dashboard</field>
        <field name="res_model">hospital.accounting.dashboard</field>
        <field name="view_mode">form,list</field>
        <field name="view_id" ref="hospital_accounting_dashboard_view_form"/>
        <field name="res_id" ref="hospital_accounting_dashboard_main"/>
        <field name="context">{'create': False}</field>
    </record>
</odoo>
