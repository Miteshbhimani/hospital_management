<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_hospital_phase3" model="ir.ui.view">
        <field name="name">account.move.form.hospital.phase3</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hospital_accounting']/group[1]" position="after">
                <group string="Phase 3 Billing Controls">
                    <group>
                        <field name="billing_mode"/>
                        <field name="corporate_contract_id"/>
                        <field name="hospital_package_id"/>
                        <field name="credit_due_date"/>
                    </group>
                    <group>
                        <field name="insurance_claim_id"/>
                        <field name="hospital_radiology_request_id"/>
                        <field name="co_pay_percent"/>
                        <field name="credit_approved_by_id"/>
                    </group>
                </group>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_approve_credit_billing" string="Approve Credit" type="object" invisible="billing_mode not in ('credit','corporate')"/>
                <button name="action_create_insurance_claim" string="Create Claim" type="object" invisible="hospital_invoice_type == False or insurance_claim_id"/>
            </xpath>
        </field>
    </record>
</odoo>
