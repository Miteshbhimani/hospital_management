<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hms_charge_view_list" model="ir.ui.view">
        <field name="name">hms.charge.view.list</field>
        <field name="model">hms.charge</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'invoiced'" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="charge_date"/>
                <field name="patient_id"/>
                <field name="department_area" widget="badge"/>
                <field name="description"/>
                <field name="quantity"/>
                <field name="unit_price"/>
                <field name="amount_total"/>
                <field name="payer_type" widget="badge"/>
                <field name="invoice_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="hms_charge_view_form" model="ir.ui.view">
        <field name="name">hms.charge.view.form</field>
        <field name="model">hms.charge</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_ready" type="object" string="Ready to Invoice" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_create_invoice" type="object" string="Create Invoice" class="oe_highlight" invisible="state not in ('draft','ready')"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('invoiced','cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,ready,invoiced"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_invoice" class="oe_stat_button" icon="fa-file-text-o" invisible="invoice_id == False" string="Invoice"/>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="charge_date"/>
                            <field name="department_area"/>
                            <field name="doctor_id"/>
                        </group>
                        <group>
                            <field name="payer_type"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="invoice_id" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Charge Details">
                        <field name="product_id"/>
                        <field name="description"/>
                        <field name="quantity"/>
                        <field name="unit_price"/>
                        <field name="amount_total" readonly="1"/>
                    </group>
                    <group string="Linked Hospital Records">
                        <field name="outpatient_id"/>
                        <field name="inpatient_id"/>
                        <field name="lab_test_id"/>
                        <field name="emergency_id"/>
                    </group>
                    <group string="Source Reference">
                        <field name="source_model" readonly="1"/>
                        <field name="source_record_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="hms_charge_view_search" model="ir.ui.view">
        <field name="name">hms.charge.view.search</field>
        <field name="model">hms.charge</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="patient_id"/>
                <field name="description"/>
                <filter string="Ready" name="ready" domain="[('state','=','ready')]"/>
                <filter string="Invoiced" name="invoiced" domain="[('state','=','invoiced')]"/>
                <filter string="Today" name="today" domain="[('charge_date','=',context_today())]"/>
                <group expand="0" string="Group By">
                    <filter string="Department" name="group_department" context="{'group_by':'department_area'}"/>
                    <filter string="Payer" name="group_payer" context="{'group_by':'payer_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    <filter string="Patient" name="group_patient" context="{'group_by':'patient_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hms_charge_action" model="ir.actions.act_window">
        <field name="name">Charge Capture</field>
        <field name="res_model">hms.charge</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="hms_charge_menu" name="Charge Capture"
              parent="hospital_accounting_menu_root" sequence="10"
              action="hms_charge_action"
              groups="hospital_accounting_management.group_hospital_cashier,hospital_accounting_management.group_hospital_accountant,hospital_accounting_management.group_hospital_finance_manager"/>
</odoo>
