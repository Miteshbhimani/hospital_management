<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hospital_radiology_request_form_accounting" model="ir.ui.view">
        <field name="name">hospital.radiology.request.form.accounting</field>
        <field name="model">hospital.radiology.request</field>
        <field name="inherit_id" ref="base_hospital_management.hospital_radiology_request_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_create_invoice" string="Create Invoice" type="object" invisible="invoiced or state == 'cancelled'"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_invoice" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="not invoice_id">
                    <field name="payment_state" widget="statinfo" string="Payment"/>
                </button>
            </xpath>
            <xpath expr="//group[@name='study_details']" position="after">
                <group string="Accounting">
                    <field name="invoice_id" readonly="1"/>
                    <field name="invoiced" readonly="1"/>
                    <field name="payment_state" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
