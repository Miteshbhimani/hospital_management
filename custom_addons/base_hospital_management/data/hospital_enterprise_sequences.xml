<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_hospital_appointment" model="ir.sequence">
        <field name="name">Hospital Appointment</field>
        <field name="code">hospital.appointment</field>
        <field name="prefix">APT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
    <record id="seq_hospital_vitals" model="ir.sequence">
        <field name="name">Hospital Vitals</field>
        <field name="code">hospital.vitals</field>
        <field name="prefix">VTL/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
    <record id="seq_hospital_consent" model="ir.sequence">
        <field name="name">Hospital Consent</field>
        <field name="code">hospital.consent</field>
        <field name="prefix">CNS/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
    <record id="seq_hospital_emergency_case" model="ir.sequence">
        <field name="name">Hospital Emergency Case</field>
        <field name="code">hospital.emergency.case</field>
        <field name="prefix">EMR/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
    <record id="seq_hospital_ai_suggestion" model="ir.sequence">
        <field name="name">Hospital AI Suggestion</field>
        <field name="code">hospital.ai.suggestion</field>
        <field name="prefix">AI/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
