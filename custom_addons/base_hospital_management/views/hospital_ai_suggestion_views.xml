<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hospital_ai_suggestion_view_list" model="ir.ui.view">
        <field name="name">hospital.ai.suggestion.view.list</field>
        <field name="model">hospital.ai.suggestion</field>
        <field name="arch" type="xml">
            <list decoration-danger="severity == 'critical'" decoration-warning="severity in ('high','medium')" decoration-muted="state in ('accepted','edited','rejected')">
                <field name="name"/>
                <field name="title"/>
                <field name="source_area" widget="badge"/>
                <field name="severity" widget="badge"/>
                <field name="patient_id"/>
                <field name="state" widget="badge"/>
                <field name="reviewed_by"/>
                <field name="reviewed_at"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="hospital_ai_suggestion_view_form" model="ir.ui.view">
        <field name="name">hospital.ai.suggestion.view.form</field>
        <field name="model">hospital.ai.suggestion</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit_review" type="object" string="Submit for Review" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_accept" type="object" string="Accept" class="oe_highlight" invisible="state not in ('draft','pending_review')"/>
                    <button name="action_mark_edited" type="object" string="Accept With Edits" invisible="state not in ('draft','pending_review')"/>
                    <button name="action_reject" type="object" string="Reject" invisible="state not in ('draft','pending_review')"/>
                    <button name="action_reset_to_draft" type="object" string="Reset" invisible="state in ('draft','pending_review')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending_review,accepted,edited,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                        <h2><field name="title" placeholder="Suggestion title"/></h2>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="source_area"/>
                            <field name="severity"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="disclaimer" readonly="1"/>
                        </group>
                        <group string="Review">
                            <field name="reviewed_by" readonly="1"/>
                            <field name="reviewed_at" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Linked Hospital Records">
                        <field name="patient_id"/>
                        <field name="appointment_id"/>
                        <field name="outpatient_id"/>
                        <field name="inpatient_id"/>
                        <field name="lab_test_id"/>
                        <field name="emergency_id"/>
                    </group>
                    <group string="Source Reference">
                        <field name="source_model" readonly="1"/>
                        <field name="source_record_id" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Suggestion">
                            <field name="suggestion_text" placeholder="Generated or rule-based suggestion requiring human review."/>
                        </page>
                        <page string="Reviewed Text">
                            <field name="reviewed_text" placeholder="Mandatory when accepting with edits."/>
                        </page>
                        <page string="Input / Context">
                            <field name="prompt_text"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="hospital_ai_suggestion_view_search" model="ir.ui.view">
        <field name="name">hospital.ai.suggestion.view.search</field>
        <field name="model">hospital.ai.suggestion</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="title"/>
                <field name="patient_id"/>
                <filter string="Pending Review" name="pending" domain="[('state','in',['draft','pending_review'])]"/>
                <filter string="Critical" name="critical" domain="[('severity','=','critical')]"/>
                <filter string="Accepted" name="accepted" domain="[('state','in',['accepted','edited'])]"/>
                <filter string="Rejected" name="rejected" domain="[('state','=','rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="Area" name="group_area" context="{'group_by':'source_area'}"/>
                    <filter string="Severity" name="group_severity" context="{'group_by':'severity'}"/>
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hospital_ai_suggestion_action" model="ir.actions.act_window">
        <field name="name">AI / Rule Suggestions</field>
        <field name="res_model">hospital.ai.suggestion</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_pending': 1}</field>
    </record>

    <record id="hospital_management_dashboard_action" model="ir.actions.client">
        <field name="name">Management &amp; AI Dashboard</field>
        <field name="tag">hospital_management_dashboard_tags</field>
    </record>

    <menuitem id="hospital_management_dashboard_menu" name="Management &amp; AI"
              parent="hospital_dashboard_menu" sequence="5"
              groups="base_hospital_management.base_hospital_management_group_manager,base_hospital_management.base_hospital_management_group_compliance_officer"
              action="hospital_management_dashboard_action"/>

    <menuitem id="hospital_ai_suggestion_menu" name="AI / Rule Suggestions"
              parent="hospital_menu_configuration" sequence="25"
              groups="base_hospital_management.base_hospital_management_group_manager,base_hospital_management.base_hospital_management_group_compliance_officer,base_hospital_management.base_hospital_management_group_doctor"
              action="hospital_ai_suggestion_action"/>
</odoo>
