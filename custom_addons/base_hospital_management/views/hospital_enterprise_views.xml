<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hospital_menu_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('base_hospital_management.base_hospital_management_group_compliance_officer')), (4, ref('base_hospital_management.base_hospital_management_group_billing_executive')), (4, ref('base_hospital_management.base_hospital_management_group_insurance_executive'))]"/>
    </record>
    <!-- Deprecated menu container from the previous delivery. It is kept inactive so module upgrades hide the old top-level Enterprise ERP menu instead of leaving a stale dropdown. -->
    <record id="hospital_menu_enterprise" model="ir.ui.menu">
        <field name="name">Enterprise ERP</field>
        <field name="parent_id" ref="hospital_menu_root"/>
        <field name="sequence">99</field>
        <field name="active" eval="False"/>
    </record>

    <!-- Patient profile extension -->
    <record id="res_partner_enterprise_view_form" model="ir.ui.view">
        <field name="name">res.partner.enterprise.view.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_hospital_management.res_partner_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='medicine']" position="after">
                <page name="enterprise_profile" string="Enterprise Patient Profile">
                    <group>
                        <group string="Acquisition &amp; Identity">
                            <field name="abha_number"/>
                            <field name="acquisition_source"/>
                            <field name="patient_category"/>
                        </group>
                        <group string="Emergency Contact">
                            <field name="emergency_contact_name"/>
                            <field name="emergency_contact_phone"/>
                            <field name="emergency_contact_relation"/>
                        </group>
                    </group>
                    <group string="Clinical Summary">
                        <field name="allergy_note" placeholder="Drug, food, environmental allergies..."/>
                        <field name="medical_history_note" placeholder="Problem list, diagnosis history, procedure history..."/>
                        <field name="family_history_note"/>
                        <field name="current_medication_note"/>
                        <field name="risk_alert_note"/>
                    </group>
                    <notebook>
                        <page string="Appointments">
                            <field name="appointment_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="appointment_date"/>
                                    <field name="doctor_id"/>
                                    <field name="priority" widget="badge"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Vitals / EMR Observations">
                            <field name="vitals_ids" readonly="1">
                                <list decoration-danger="abnormal == True">
                                    <field name="name"/>
                                    <field name="recorded_at"/>
                                    <field name="temperature_c"/>
                                    <field name="pulse_rate"/>
                                    <field name="systolic_bp"/>
                                    <field name="diastolic_bp"/>
                                    <field name="spo2"/>
                                    <field name="abnormal"/>
                                    <field name="abnormal_reason"/>
                                </list>
                            </field>
                        </page>
                        <page string="Consent Records">
                            <field name="consent_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="consent_type"/>
                                    <field name="date"/>
                                    <field name="valid_until"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Appointment & Queue -->
    <record id="hospital_appointment_view_list" model="ir.ui.view">
        <field name="name">hospital.appointment.view.list</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list decoration-danger="priority == '2'" decoration-warning="state in ('checked_in','in_consultation')" decoration-muted="state in ('cancelled','no_show')">
                <field name="token_number"/>
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="department_id"/>
                <field name="appointment_date"/>
                <field name="source"/>
                <field name="visit_type"/>
                <field name="priority" widget="badge"/>
                <field name="waiting_minutes"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="hospital_appointment_view_form" model="ir.ui.view">
        <field name="name">hospital.appointment.view.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_schedule" string="Schedule" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_check_in" string="Check In" type="object" class="oe_highlight" invisible="state != 'scheduled'"/>
                    <button name="action_start_consultation" string="Start Consultation" type="object" class="oe_highlight" invisible="state != 'checked_in'"/>
                    <button name="action_done" string="Done" type="object" class="oe_highlight" invisible="state != 'in_consultation'"/>
                    <button name="action_create_opd" string="Create OPD" type="object" invisible="state not in ('checked_in','in_consultation','done') or outpatient_id != False"/>
                    <button name="action_no_show" string="No-show" type="object" invisible="state not in ('scheduled','checked_in')"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done','cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,scheduled,checked_in,in_consultation,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_create_opd" type="object" class="oe_stat_button" icon="fa-stethoscope" invisible="outpatient_id == False" string="OPD Visit"/>
                    </div>
                    <h1><field name="name"/></h1>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="doctor_id"/>
                            <field name="department_id"/>
                            <field name="appointment_date"/>
                            <field name="token_number" readonly="1"/>
                        </group>
                        <group>
                            <field name="source"/>
                            <field name="visit_type"/>
                            <field name="priority"/>
                            <field name="checked_in_at" readonly="1"/>
                            <field name="consultation_started_at" readonly="1"/>
                            <field name="completed_at" readonly="1"/>
                            <field name="waiting_minutes" readonly="1"/>
                            <field name="outpatient_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="chief_complaint"/>
                        <field name="notes"/>
                        <field name="no_show_reason" invisible="state not in ('no_show','cancelled')"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="hospital_appointment_view_calendar" model="ir.ui.view">
        <field name="name">hospital.appointment.view.calendar</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <calendar string="Appointments" date_start="appointment_date" color="doctor_id" mode="week">
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="hospital_appointment_view_search" model="ir.ui.view">
        <field name="name">hospital.appointment.view.search</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <filter string="Today" name="today" domain="[('appointment_date','&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')), ('appointment_date','&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
                <filter string="Emergency" name="emergency" domain="[('priority','=','2')]"/>
                <filter string="Waiting" name="waiting" domain="[('state','in',['scheduled','checked_in'])]"/>
                <group expand="0" string="Group By">
                    <filter string="Doctor" name="group_doctor" context="{'group_by':'doctor_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    <filter string="Source" name="group_source" context="{'group_by':'source'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hospital_appointment_action" model="ir.actions.act_window">
        <field name="name">Appointment &amp; Queue</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">calendar,list,form</field>
        <field name="help" type="html"><p class="o_view_nocontent_smiling_face">Create an appointment or walk-in queue token.</p></field>
    </record>
    <menuitem id="hospital_appointment_enterprise_menu" name="Appointment &amp; Queue" parent="hospital_menu_appointment" sequence="0" action="hospital_appointment_action"
              groups="base_hospital_management.base_hospital_management_group_manager,base_hospital_management.base_hospital_management_group_doctor,base_hospital_management.base_hospital_management_group_nurse,base_hospital_management.base_hospital_management_group_receptionist"/>

    <!-- Vitals -->
    <record id="hospital_vitals_view_list" model="ir.ui.view">
        <field name="name">hospital.vitals.view.list</field>
        <field name="model">hospital.vitals</field>
        <field name="arch" type="xml">
            <list decoration-danger="abnormal == True">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="recorded_at"/>
                <field name="temperature_c"/>
                <field name="pulse_rate"/>
                <field name="respiratory_rate"/>
                <field name="systolic_bp"/>
                <field name="diastolic_bp"/>
                <field name="spo2"/>
                <field name="triage_category" widget="badge"/>
                <field name="abnormal"/>
                <field name="abnormal_reason"/>
            </list>
        </field>
    </record>

    <record id="hospital_vitals_view_form" model="ir.ui.view">
        <field name="name">hospital.vitals.view.form</field>
        <field name="model">hospital.vitals</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1><field name="name"/></h1>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="outpatient_id"/>
                            <field name="inpatient_id"/>
                            <field name="recorded_by_id" readonly="1"/>
                            <field name="recorded_at"/>
                        </group>
                        <group>
                            <field name="triage_category"/>
                            <field name="abnormal" readonly="1"/>
                            <field name="abnormal_reason" readonly="1"/>
                        </group>
                    </group>
                    <group string="Vitals">
                        <group>
                            <field name="temperature_c"/>
                            <field name="pulse_rate"/>
                            <field name="respiratory_rate"/>
                            <field name="spo2"/>
                        </group>
                        <group>
                            <field name="systolic_bp"/>
                            <field name="diastolic_bp"/>
                            <field name="height_cm"/>
                            <field name="weight_kg"/>
                            <field name="bmi" readonly="1"/>
                            <field name="pain_score"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="hospital_vitals_view_search" model="ir.ui.view">
        <field name="name">hospital.vitals.view.search</field>
        <field name="model">hospital.vitals</field>
        <field name="arch" type="xml">
            <search>
                <field name="patient_id"/>
                <filter string="Abnormal" name="abnormal" domain="[('abnormal','=',True)]"/>
                <filter string="Critical Triage" name="critical" domain="[('triage_category','=','red')]"/>
                <group expand="0" string="Group By">
                    <filter string="Patient" name="group_patient" context="{'group_by':'patient_id'}"/>
                    <filter string="Triage" name="group_triage" context="{'group_by':'triage_category'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hospital_vitals_action" model="ir.actions.act_window">
        <field name="name">Vitals / EMR Observations</field>
        <field name="res_model">hospital.vitals</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="hospital_vitals_menu" name="Vitals / EMR" parent="appointment_menu_patient" sequence="4" action="hospital_vitals_action"
              groups="base_hospital_management.base_hospital_management_group_manager,base_hospital_management.base_hospital_management_group_doctor,base_hospital_management.base_hospital_management_group_nurse"/>

    <!-- Consent -->
    <record id="hospital_consent_view_list" model="ir.ui.view">
        <field name="name">hospital.consent.view.list</field>
        <field name="model">hospital.consent</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'signed'" decoration-danger="state == 'revoked'" decoration-muted="state == 'expired'">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="consent_type"/>
                <field name="date"/>
                <field name="valid_until"/>
                <field name="signed_by"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="hospital_consent_view_form" model="ir.ui.view">
        <field name="name">hospital.consent.view.form</field>
        <field name="model">hospital.consent</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sign" string="Mark Signed" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_revoke" string="Revoke" type="object" invisible="state != 'signed'"/>
                    <button name="action_expire" string="Expire" type="object" invisible="state not in ('draft','signed')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,signed,revoked,expired"/>
                </header>
                <sheet>
                    <h1><field name="name"/></h1>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="consent_type"/>
                            <field name="date"/>
                            <field name="valid_until"/>
                        </group>
                        <group>
                            <field name="signed_by"/>
                            <field name="witness"/>
                            <field name="attachment_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="summary"/>
                        <field name="purpose"/>
                        <field name="allowed_data_scope"/>
                        <field name="revoked_reason" invisible="state != 'revoked'"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="hospital_consent_view_search" model="ir.ui.view">
        <field name="name">hospital.consent.view.search</field>
        <field name="model">hospital.consent</field>
        <field name="arch" type="xml">
            <search>
                <field name="patient_id"/>
                <filter string="Signed" name="signed" domain="[('state','=','signed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_type" context="{'group_by':'consent_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="hospital_consent_action" model="ir.actions.act_window">
        <field name="name">Consent Management</field>
        <field name="res_model">hospital.consent</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="hospital_consent_menu" name="Consent Management" parent="appointment_menu_patient" sequence="5" action="hospital_consent_action"
              groups="base_hospital_management.base_hospital_management_group_manager,base_hospital_management.base_hospital_management_group_receptionist,base_hospital_management.base_hospital_management_group_compliance_officer"/>

    <!-- Emergency -->
    <record id="hospital_emergency_case_view_list" model="ir.ui.view">
        <field name="name">hospital.emergency.case.view.list</field>
        <field name="model">hospital.emergency.case</field>
        <field name="arch" type="xml">
            <list decoration-danger="triage_category == 'red'" decoration-warning="triage_category in ('yellow','orange')" decoration-muted="state in ('discharged','cancelled')">
                <field name="name"/>
                <field name="arrival_time"/>
                <field name="patient_id"/>
                <field name="patient_name"/>
                <field name="triage_category" widget="badge"/>
                <field name="doctor_id"/>
                <field name="medico_legal_case"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="hospital_emergency_case_view_form" model="ir.ui.view">
        <field name="name">hospital.emergency.case.view.form</field>
        <field name="model">hospital.emergency.case</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_triage" string="Triage" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_start_treatment" string="Start Treatment" type="object" class="oe_highlight" invisible="state != 'triaged'"/>
                    <button name="action_open_inpatient" string="Convert to IPD" type="object" invisible="state not in ('triaged','under_treatment') or patient_id == False"/>
                    <button name="action_discharge" string="Discharge" type="object" invisible="state not in ('triaged','under_treatment')"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('discharged','cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,triaged,under_treatment,converted_ipd,discharged"/>
                </header>
                <sheet>
                    <h1><field name="name"/></h1>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="patient_name" invisible="patient_id != False"/>
                            <field name="arrival_time"/>
                            <field name="arrival_mode"/>
                            <field name="triage_category"/>
                        </group>
                        <group>
                            <field name="doctor_id"/>
                            <field name="nurse_id"/>
                            <field name="medico_legal_case"/>
                            <field name="inpatient_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="presenting_complaint"/>
                        <field name="initial_assessment"/>
                        <field name="procedure_notes"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="hospital_emergency_case_action" model="ir.actions.act_window">
        <field name="name">Emergency Triage</field>
        <field name="res_model">hospital.emergency.case</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="hospital_emergency_case_menu" name="Emergency Triage" parent="hospital_menu_appointment" sequence="2" action="hospital_emergency_case_action"
              groups="base_hospital_management.base_hospital_management_group_manager,base_hospital_management.base_hospital_management_group_doctor,base_hospital_management.base_hospital_management_group_nurse,base_hospital_management.base_hospital_management_group_receptionist"/>
</odoo>
