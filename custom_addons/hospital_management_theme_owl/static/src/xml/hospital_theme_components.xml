<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Reusable Owl action card used by the floating hospital quick panel. -->
    <t t-name="hospital_management_theme_owl.ActionCard" owl="1">
        <button type="button" t-att-class="'hmo-quick-item hmo-tone-' + props.item.tone" t-on-click="select">
            <span class="hmo-quick-icon"><i t-att-class="props.item.icon"/></span>
            <span>
                <span class="hmo-quick-title" t-esc="props.item.title"/>
                <span class="hmo-quick-subtitle" t-esc="props.item.subtitle"/>
            </span>
        </button>
    </t>

    <!-- Floating Owl panel. It is displayed only when theme_detector.js finds a hospital screen. -->
    <t t-name="hospital_management_theme_owl.QuickPanel" owl="1">
        <div t-att-class="'hmo-quick-panel ' + (state.open ? 'is-open ' : '') + (state.compact ? 'is-compact ' : '')" aria-live="polite">
            <button type="button" class="hmo-quick-toggle" title="Hospital quick actions" aria-label="Hospital quick actions" t-on-click="toggleOpen">
                <i class="fa fa-hospital-o"/>
            </button>
            <div class="hmo-quick-sheet" t-if="state.open" role="region" aria-label="Hospital quick actions">
                <div class="hmo-quick-head">
                    <div>
                        <div class="hmo-eyebrow">Hospital Workspace</div>
                        <h3>Quick actions</h3>
                    </div>
                    <button type="button" class="hmo-density-toggle" title="Toggle quick-action density" aria-label="Toggle quick-action density" t-on-click="toggleCompact">
                        <t t-if="state.compact">Comfort</t><t t-else="">Compact</t>
                    </button>
                </div>
                <div class="hmo-quick-grid">
                    <t t-foreach="quickActions" t-as="item" t-key="item.action">
                        <HospitalThemeActionCard item="item" onSelect.bind="openQuickAction"/>
                    </t>
                </div>
                <div class="hmo-quick-footer">
                    Theme module only: opens existing base_hospital_management actions and does not change workflows.
                </div>
            </div>
        </div>
    </t>
</templates>
