<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Lightweight visual extension for existing Owl dashboards. The base templates remain unchanged. -->
    <t t-inherit="ReceptionDashboard" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[contains(@class, 'hm-hero')][1]" position="before">
            <div class="hmo-dashboard-pulse">
                <div class="hmo-pulse-title"><span class="hmo-pulse-dot"/> Reception command center</div>
                <div class="hmo-pulse-note">Clean triage, queue, appointment, and admission workspace theme active.</div>
            </div>
        </xpath>
    </t>

    <t t-inherit="DoctorDashboard" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[contains(@class, 'hm-hero')][1]" position="before">
            <div class="hmo-dashboard-pulse">
                <div class="hmo-pulse-title"><span class="hmo-pulse-dot"/> Clinical workspace</div>
                <div class="hmo-pulse-note">Patient queue, vitals, EMR, IPD, and surgery screens are visually enhanced only.</div>
            </div>
        </xpath>
    </t>

    <t t-inherit="LabDashboard" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[contains(@class, 'hm-hero')][1]" position="before">
            <div class="hmo-dashboard-pulse">
                <div class="hmo-pulse-title"><span class="hmo-pulse-dot"/> Laboratory operations</div>
                <div class="hmo-pulse-note">Sample, result, approval, and turnaround views use the hospital theme layer.</div>
            </div>
        </xpath>
    </t>

    <t t-inherit="PharmacyDashboard" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[contains(@class, 'hm-hero')][1]" position="before">
            <div class="hmo-dashboard-pulse">
                <div class="hmo-pulse-title"><span class="hmo-pulse-dot"/> Pharmacy command center</div>
                <div class="hmo-pulse-note">Prescription fulfilment, inventory, and billing screens are visually enhanced only.</div>
            </div>
        </xpath>
    </t>
</templates>
